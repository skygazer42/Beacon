# Beacon 环境变量示例（开发/本机）
# ------------------------------------------------------------
# 用法（zsh/bash）：
#   set -a
#   source .env
#   set +a
#
# 注意：
# - 本文件是可提交的模板：复制为 `.env` 后按需修改

# ========== 部署模式（Edge / Cloud）==========
# BEACON_DEPLOYMENT_MODE：部署模式开关：
# - edge：边缘/本地交付（默认）
# - cloud：云端 SaaS（告警聚合 + 截图上云）
BEACON_DEPLOYMENT_MODE=edge

# BEACON_OPEN_API_TOKEN：开放接口共享 Token（HTTP Header: `X-Beacon-Token`）。留空表示不启用 Token（默认仅允许本机访问 open/api 接口）。
BEACON_OPEN_API_TOKEN=

# BEACON_REQUIRE_OPEN_API_TOKEN：是否强制所有 open/api 接口都必须携带 Token（1/true/yes/on）。公网/反代部署强烈建议设为 1。
BEACON_REQUIRE_OPEN_API_TOKEN=

# 本地账号密码最短长度；Django 的常见密码、纯数字和用户属性相似度校验仍会同时执行。
BEACON_PASSWORD_MIN_LENGTH=8

# ========== LDAP/AD 登录（可选）==========
# 说明：
# - 启用后：/login 在本地密码校验失败或本地用户不存在时，会 best-effort 回退到 LDAP/AD 认证
# - 认证成功后：可自动创建/更新本地 Django User（便于在 Beacon 内继续配置权限、TOTP 等）
# - 依赖：需要安装 `ldap3`（建议放到 requirements-optional.txt 或你的交付依赖里）
#
# 两种常见接入方式：
# - 方式 A（直连 bind）：配置 `BEACON_LDAP_USER_DN_TEMPLATE`（例如 uid={username},ou=People,dc=example,dc=com）
# - 方式 B（service 搜索 DN 再 bind）：配置 `BEACON_LDAP_BIND_DN/BEACON_LDAP_BIND_PASSWORD/BEACON_LDAP_BASE_DN/BEACON_LDAP_USER_FILTER`

# BEACON_LDAP_ENABLED：是否启用 LDAP 登录（1=启用，0=禁用）。
BEACON_LDAP_ENABLED=0

# BEACON_LDAP_URL：LDAP/AD 地址（示例：ldap://127.0.0.1:389 或 ldaps://ad.example.com:636）。
BEACON_LDAP_URL=

# BEACON_LDAP_USE_SSL：是否使用 SSL（ldaps）。若 URL 以 ldaps:// 开头则会自动视为开启。
BEACON_LDAP_USE_SSL=0

# BEACON_LDAP_STARTTLS：是否使用 StartTLS（ldap:// + StartTLS）。某些环境会要求开启。
BEACON_LDAP_STARTTLS=0

# BEACON_LDAP_TLS_VERIFY：是否校验证书（1=校验，0=不校验）。生产建议保持 1 并正确配置证书链。
BEACON_LDAP_TLS_VERIFY=1

# BEACON_LDAP_CONNECT_TIMEOUT_SECONDS：LDAP 连接超时（秒，默认空=库默认；建议 5）。
BEACON_LDAP_CONNECT_TIMEOUT_SECONDS=

# 方式 A：直连 bind（可选）
# BEACON_LDAP_USER_DN_TEMPLATE：用户 DN 模板（支持 {username}）。
BEACON_LDAP_USER_DN_TEMPLATE=

# 方式 B：service account 搜索 DN 再 bind（可选）
BEACON_LDAP_BIND_DN=
BEACON_LDAP_BIND_PASSWORD=
BEACON_LDAP_BASE_DN=
# BEACON_LDAP_USER_FILTER：用户搜索过滤器（支持 {username}，会做必要的 filter escaping）。
# - OpenLDAP 示例：(uid={username})
# - AD 示例：(|(sAMAccountName={username})(userPrincipalName={username}))
BEACON_LDAP_USER_FILTER=

# BEACON_LDAP_EMAIL_ATTR：从 LDAP entry 读取 email 的字段名（默认 mail）。
BEACON_LDAP_EMAIL_ATTR=mail

# ========== OAuth2/OIDC SSO 登录（可选）==========
# 说明：
# - /login/oidc/start：跳转到 OIDC 授权页
# - /login/oidc/callback：回调后交换 code 并在 Beacon 内创建/登录本地账号
# - /logout：若配置了 end_session_endpoint，会重定向到 OIDC Provider 的登出页
#
# 你需要在 OIDC Provider 里配置回调地址（Redirect URI），开发环境通常是：
# - http://<beacon-host>:9991/login/oidc/callback
#
# 本实现为“工业 best-effort”：
# - 会校验 state（防 CSRF）
# - OIDC 回调强制校验 id_token 签名、issuer、audience 与时间声明
#
# 需要配置严格校验参数：
# - 配置 BEACON_OIDC_JWKS_URI（Provider 的 JWKS 地址）
# - 配置 BEACON_OIDC_ISSUER（Provider 的 issuer）
# - 可选开启 BEACON_OIDC_REQUIRE_NONCE=1（要求 nonce 匹配）

BEACON_OIDC_ENABLED=0
BEACON_OIDC_CLIENT_ID=
BEACON_OIDC_CLIENT_SECRET=
BEACON_OIDC_AUTHORIZATION_ENDPOINT=
BEACON_OIDC_TOKEN_ENDPOINT=
BEACON_OIDC_USERINFO_ENDPOINT=
BEACON_OIDC_END_SESSION_ENDPOINT=
BEACON_OIDC_SCOPE=openid email profile
# BEACON_OIDC_PROMPT=login
BEACON_OIDC_HTTP_TIMEOUT_SECONDS=8

# 严格校验参数
BEACON_OIDC_JWKS_URI=
BEACON_OIDC_ISSUER=
BEACON_OIDC_REQUIRE_NONCE=0
BEACON_OIDC_CLOCK_SKEW_SECONDS=60
BEACON_OIDC_JWKS_CACHE_SECONDS=300

# userinfo（可选）
# - 一些 Provider 的 email / group / role 更适合从 userinfo 获取
BEACON_OIDC_USERINFO_ENABLED=0
BEACON_OIDC_USERINFO_PREFER=1

# 多 Provider（可选）
# - 配置后可通过：/login/oidc/start?provider=<id> 选择不同 Provider
# - `BEACON_OIDC_PROVIDER_DEFAULT` 仅在配置了 providers JSON 时生效（legacy 单 Provider 不需要）
BEACON_OIDC_PROVIDER_DEFAULT=
# BEACON_OIDC_PROVIDERS_JSON：JSON 格式（不要带注释）。示例：
# {"p1":{"client_id":"...","client_secret":"...","authorization_endpoint":"...","token_endpoint":"...","issuer":"...","jwks_uri":"..."}}
BEACON_OIDC_PROVIDERS_JSON=

# 账号绑定策略（工业推荐生产不要用纯 username/email 自动绑定，避免账号串号）
# - auto: (legacy) username -> email -> create
# - username/email: 仅按 username 或 email 尝试绑定
# - create: 永远新建本地账号（若重名会自动加后缀）
# - deny: 仅允许已存在的 OIDC 映射账号登录
BEACON_OIDC_ACCOUNT_LINK_MODE=auto

# 可选：硬拦截 required groups（强烈建议用于企业交付）
# - 配置后：OIDC 回调要求用户至少命中 1 个组，否则直接 403（不会创建/绑定本地账号）
# - 示例：BEACON_OIDC_REQUIRED_GROUPS=beacon_allowed,beacon_admin
BEACON_OIDC_REQUIRED_GROUPS=

# 角色/权限映射（可选）
# - staff/superuser 仅在配置了 group 列表时才会生效
BEACON_OIDC_STAFF_GROUPS=
BEACON_OIDC_SUPERUSER_GROUPS=
BEACON_OIDC_SYNC_USER_FLAGS=1

# groups -> Admin Web 模块权限 allowlist（可选）
# 注意：一旦给用户生成了非空 permissions_json，就会按 allowlist 收敛为“未授予=禁止”
BEACON_OIDC_PERMISSIONS_BY_GROUP_JSON=
BEACON_OIDC_SYNC_USER_PERMISSIONS=0

# ========== TOTP 敏感操作二次确认（可选）==========
# 说明：
# - 仅对“已启用 TOTP”的账号生效
# - 通过 `BEACON_TOTP_SENSITIVE_REAUTH_PREFIXES` 配置需要二次确认的敏感路径前缀
# - 二次确认入口：个人信息页（/profile）-> “敏感操作二次确认”
BEACON_TOTP_SENSITIVE_REAUTH_ENABLED=0
BEACON_TOTP_SENSITIVE_REAUTH_WINDOW_SECONDS=300
# 示例：user/api/,ops/apikeys/api/,config/api/system/save
BEACON_TOTP_SENSITIVE_REAUTH_PREFIXES=

# ========== App-Shell Legacy API 阻断（灰度，可选）==========
# 说明：
# - React app-shell 客户端会携带 `X-Beacon-App-Shell: 1`
# - 打开阻断后，app-shell 客户端访问 legacy API（非 /api/app-shell/*）会返回 410
# - allowlist 支持逗号分隔：
#   - 精确路径：stream/getAutoStartConfig
#   - 前缀路径：stream/* 或 stream/
BEACON_BLOCK_LEGACY_API_FOR_APP_SHELL=0
BEACON_BLOCK_LEGACY_API_ALLOWLIST=

# ========== 数字人监管运行时（Beacon 本地承接）==========
# 说明：
# - 当前数字人页面和运行时已直接落到 Beacon Django，不再要求配置外部数字人后端代理地址
# - 采集端与日志上报端应直接访问 Beacon 的 `/open/agent/*` 与 `/open/human/report`
# - 若要启用“多实例共享防重放”或“对象存储截图”，需要补装 Admin/requirements-optional.txt

# BEACON_DIGITAL_HUMAN_AUTHORIZATION_SECRET：设备 machineCode 生成/校验密钥。
# 要求：
# - 必须与真实采集端生成 machineCode 时使用的密钥一致
# - 未设置时相关设备授权接口返回 503；仓库不提供共享默认密钥
BEACON_DIGITAL_HUMAN_AUTHORIZATION_SECRET=

# BEACON_DIGITAL_HUMAN_UPLOAD_AUTH_SM4_SECRET_KEY：采集端上报 Authorization 密文使用的 SM4 密钥。
# 要求：
# - 必须与真实采集端加密 `machineCode*yyyyMMddHHmmss` 时使用的密钥一致
# - 未设置时相关上报接口返回 503；仓库不提供共享默认密钥
BEACON_DIGITAL_HUMAN_UPLOAD_AUTH_SM4_SECRET_KEY=

# BEACON_DIGITAL_HUMAN_REPORT_DEFAULT_INTERVAL_SEC：Beacon 返回给采集端的默认下一次上报间隔（秒，默认 30）。
BEACON_DIGITAL_HUMAN_REPORT_DEFAULT_INTERVAL_SEC=30

# BEACON_DIGITAL_HUMAN_REPORT_IMAGE_MAX_BYTES：设备截图 Base64 解码后的大小上限（字节，默认 524288 = 512 KiB）。
BEACON_DIGITAL_HUMAN_REPORT_IMAGE_MAX_BYTES=524288

# BEACON_DIGITAL_HUMAN_REPLAY_REDIS_URL：数字人防重放专用 Redis 连接串。
# 推荐生产优先设置这个值，保证多实例 Beacon 间共享 machineCode 重放拦截状态。
BEACON_DIGITAL_HUMAN_REPLAY_REDIS_URL=

# BEACON_DIGITAL_HUMAN_REDIS_URL：与上面等价的兼容别名；未设置专用地址时可复用。
BEACON_DIGITAL_HUMAN_REDIS_URL=

# BEACON_DIGITAL_HUMAN_REPLAY_CACHE_PREFIX：Redis 防重放 key 前缀，默认 beacon:digital-human:replay。
BEACON_DIGITAL_HUMAN_REPLAY_CACHE_PREFIX=

# BEACON_DIGITAL_HUMAN_S3_BUCKET：数字人截图对象存储 bucket。
# 设置后，设备截图优先写入该 bucket；不设置则回退到 BEACON_CLOUD_S3_BUCKET，再回退本地 uploadDir。
BEACON_DIGITAL_HUMAN_S3_BUCKET=

# ========== 报警落库前“大模型预检”（可选）==========
# 说明：
# - 在报警写入数据库/写盘前，先调用外部预检服务进行二次过滤（例如：大模型预检、黑白名单、业务规则等）
# - 预检不通过时：报警不会落库/落盘（返回 stored=false 或 msg=filtered）
# - 工业默认建议 fail-open（预检服务抖动时不丢报警）；如你明确要“宁可误丢也不误报”，可改 fail-open=0

# BEACON_ALARM_PRECHECK_ENABLED：是否启用预检（1=开启，0=关闭）。
BEACON_ALARM_PRECHECK_ENABLED=0

# BEACON_ALARM_PRECHECK_URL：预检服务 URL（示例：http://127.0.0.1:9000/precheck）。
BEACON_ALARM_PRECHECK_URL=

# BEACON_ALARM_PRECHECK_TIMEOUT_SECONDS：预检超时（秒，默认 5）。
BEACON_ALARM_PRECHECK_TIMEOUT_SECONDS=5

# BEACON_ALARM_PRECHECK_FAIL_OPEN：预检失败时是否放行（1=放行并继续落库；0=拦截并丢弃）。
BEACON_ALARM_PRECHECK_FAIL_OPEN=1

# ========== OpenAPI 文件服务（可选，只读下载）==========
# 说明：
# - 用于工业交付：把任意硬盘目录映射为受 Token 保护的 HTTP 只读下载服务
# - 安全建议：仅在内网/可信反代环境启用，并开启 `BEACON_REQUIRE_OPEN_API_TOKEN=1`

# BEACON_FILE_SERVICE_ENABLED：是否启用文件服务（1=开启，0=关闭）。
BEACON_FILE_SERVICE_ENABLED=0

# BEACON_FILE_SERVICE_ROOT_DIR：文件服务根目录（建议绝对路径）。open URL 中的相对路径会被严格校验，防止目录穿越。
BEACON_FILE_SERVICE_ROOT_DIR=

# BEACON_UPLOAD_DIR：覆盖 `config.json.uploadDir`（报警视频/截图/录制等落盘目录）。建议用绝对路径；也可用相对路径（相对 config.json 所在目录）。
BEACON_UPLOAD_DIR=

# BEACON_MODEL_DIR：覆盖 `config.json.modelDir`（模型文件目录）。建议用绝对路径；也可用相对路径（相对 config.json 所在目录）。
BEACON_MODEL_DIR=

# ========== API 推理（外部服务）稳定性保护 ==========
# 说明：
# - 仅影响 `basic_source=api` 类型的基础算法（调用外部 HTTP 推理服务）
# - 支持用环境变量覆盖 `config.json` 的 apiInfer* 字段（生产推荐）
# - 外部服务慢/不稳定时，可以通过超时/重试/熔断/最小调用间隔，避免“消费 < 生产”时队列堆积导致系统崩溃

# BEACON_API_INFER_CONNECT_TIMEOUT_SECONDS：API 推理服务连接超时（秒，默认 2；范围 1~60）。
BEACON_API_INFER_CONNECT_TIMEOUT_SECONDS=

# BEACON_API_INFER_TIMEOUT_SECONDS：API 推理服务请求总超时（秒，默认 5；范围 1~300）。包含连接、发送、等待响应等。
BEACON_API_INFER_TIMEOUT_SECONDS=

# BEACON_API_INFER_RETRY_MAX：API 推理失败重试次数（默认 0；范围 0~10）。建议谨慎开启，避免“雪崩重试”。
BEACON_API_INFER_RETRY_MAX=

# BEACON_API_INFER_CIRCUIT_BREAKER_FAILS：熔断阈值（连续失败次数，默认 5；范围 0~100；0=禁用熔断）。
BEACON_API_INFER_CIRCUIT_BREAKER_FAILS=

# BEACON_API_INFER_CIRCUIT_BREAKER_OPEN_SECONDS：熔断打开时长（秒，默认 10；范围 0~3600）。打开期间会快速跳过 API 推理，保护系统稳定性。
BEACON_API_INFER_CIRCUIT_BREAKER_OPEN_SECONDS=

# BEACON_API_INFER_MIN_INTERVAL_MS：API 推理最小调用间隔（毫秒，默认 0；0=禁用）。用于主动限流，避免弱机/外部服务被打爆。
BEACON_API_INFER_MIN_INTERVAL_MS=

# ========== GB28181 外部平台适配（WVP / 自研平台） ==========
# 说明：
# - Admin 通过 provider API 获取“可播放 play_url”（RTSP/HTTP-FLV/HLS 等），再用本机 ZLM `addStreamProxy` 拉回
# - Analyzer 始终从本机 ZLM 拉流，避免对 Analyzer 引入 SIP/GB 信令依赖
# - 模板支持占位符：{deviceId} {channelId}

# BEACON_GB28181_PROVIDER：GB28181 外部平台类型（wvp/custom）。默认 wvp。
BEACON_GB28181_PROVIDER=wvp

# BEACON_GB28181_WVP_BASE_URL：WVP 平台 API Base URL（示例：http://127.0.0.1:18080）。
BEACON_GB28181_WVP_BASE_URL=

# BEACON_GB28181_WVP_START_PLAY_URL_TEMPLATE：WVP 启动点播模板（示例：/api/gb/start?deviceId={deviceId}&channelId={channelId}）。
BEACON_GB28181_WVP_START_PLAY_URL_TEMPLATE=

# BEACON_GB28181_WVP_STOP_PLAY_URL_TEMPLATE：WVP 停止点播模板（示例：/api/gb/stop?deviceId={deviceId}&channelId={channelId}）。
BEACON_GB28181_WVP_STOP_PLAY_URL_TEMPLATE=

# BEACON_GB28181_CUSTOM_BASE_URL：自研平台 API Base URL（示例：http://127.0.0.1:28080）。
BEACON_GB28181_CUSTOM_BASE_URL=

# BEACON_GB28181_CUSTOM_START_PLAY_URL_TEMPLATE：自研平台启动点播模板（支持 {deviceId} {channelId}）。
BEACON_GB28181_CUSTOM_START_PLAY_URL_TEMPLATE=

# BEACON_GB28181_CUSTOM_STOP_PLAY_URL_TEMPLATE：自研平台停止点播模板（支持 {deviceId} {channelId}）。
BEACON_GB28181_CUSTOM_STOP_PLAY_URL_TEMPLATE=

# BEACON_GB28181_HTTP_TIMEOUT_SECONDS：provider HTTP 超时（秒，默认 8；范围 1~60）。
BEACON_GB28181_HTTP_TIMEOUT_SECONDS=

# BEACON_FRAMEPOOL_MAX_FRAMES：Analyzer 内部 FramePool 最大帧数（总量上限）。
# 说明：
# - 用于防止“生产速度 > 消费速度”时内存无限增长导致崩溃（弱机/多路/推流/报警叠加场景常见）
# - 设置为正整数（例如 60/80/120）
# - 留空或 0 表示自动：按 `BEACON_FRAMEPOOL_BUDGET_MB` 预算 + 分辨率估算（默认 128MB）
# - 1080p BGR 单帧约 6MB：20 帧≈120MB；80 帧≈480MB（仅 FramePool 上限，不含其他内存）
BEACON_FRAMEPOOL_MAX_FRAMES=

# BEACON_FRAMEPOOL_BUDGET_MB：当未设置 `BEACON_FRAMEPOOL_MAX_FRAMES` 时，FramePool 自动上限预算（单位 MB，默认 128）。
# 建议：
# - 弱机（内存较小/多路布控）：64 或 32
# - 高配/少路数：可适当调高
BEACON_FRAMEPOOL_BUDGET_MB=

# BEACON_DISABLE_BACKGROUND：是否禁用后台线程/守护任务（1=禁用，0=启用）。用于本地调试、跑单测或只想启动 Web 管理端时。
BEACON_DISABLE_BACKGROUND=0

# DJANGO_DEBUG_STARTUP_LOGS：是否输出更多 Django 启动调试日志（1=开启，0=关闭）。
DJANGO_DEBUG_STARTUP_LOGS=0

# ========== OpenTelemetry Tracing（可选；Admin/Analyzer/MediaServer）==========
# 说明：
# - 默认关闭；只在需要排查“跨服务调用链”时启用
# - Trace context：W3C traceparent（Admin requests 出站会自动传播）
# - Admin（Django）：OTLP/HTTP exporter（OTLP/HTTP 常见 collector 端口 4318，路径通常为 /v1/traces）
# - Analyzer（C++）：
#   - 若以 `-DBEACON_ENABLE_OTEL=ON` 构建并链接 opentelemetry-cpp：使用 OTLP/HTTP exporter
#   - 否则（默认/轻量构建）：best-effort 使用 Zipkin v2 JSON exporter（通过 collector 的 Zipkin receiver 接入）
# - MediaServer（ZLMediaKit）：best-effort 使用 Zipkin v2 JSON exporter（通过 collector 的 Zipkin receiver 接入）
# - 工业推荐：统一接入 OpenTelemetry Collector（可同时接收 OTLP 4317/4318 + Zipkin 9411，再转发到 Jaeger/Tempo 等后端）
#
# BEACON_OTEL_ENABLED：是否启用 OpenTelemetry tracing（1=启用，0=禁用）。
BEACON_OTEL_ENABLED=0
#
# BEACON_OTEL_OTLP_ENDPOINT：OTLP HTTP endpoint（可填 base 或完整 /v1/traces）。
# 示例（base）：http://127.0.0.1:4318
# 示例（full）：http://127.0.0.1:4318/v1/traces
BEACON_OTEL_OTLP_ENDPOINT=
#
# 可选：Zipkin endpoint（用于 MediaServer 与 Analyzer 轻量 exporter；不设则会尝试从 OTLP endpoint 推导到 :9411/api/v2/spans）。
# 示例（base）：http://127.0.0.1:9411
# 示例（full）：http://127.0.0.1:9411/api/v2/spans
BEACON_OTEL_ZIPKIN_ENDPOINT=
#
# BEACON_OTEL_SAMPLE_RATIO：采样率（0..1）。
# - 本地调试：建议 1
# - 生产环境：建议 0.1 或更低
BEACON_OTEL_SAMPLE_RATIO=1
#
# 可选：服务名（不设时默认 beacon-admin；也可使用标准 OTEL_SERVICE_NAME）。
# BEACON_OTEL_SERVICE_NAME=beacon-admin
#
# 标准 OTEL_* 兼容（可选，适合已有统一 OTel 环境变量规范的环境）：
# OTEL_SERVICE_NAME=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_ZIPKIN_ENDPOINT=

# BEACON_LOG_LEVEL：日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL），默认 INFO。
BEACON_LOG_LEVEL=INFO

# BEACON_LOG_FORMAT：日志格式（text/json）。text 适合本地直接阅读；json 适合日志系统采集与检索（ELK/Loki）。
BEACON_LOG_FORMAT=text

# BEACON_LOG_TO_FILE：是否同时写入本地日志文件（1/true/yes/on=开启）。默认 0（仅输出到控制台）。
BEACON_LOG_TO_FILE=0

# BEACON_LOG_DIR：日志目录（开启 BEACON_LOG_TO_FILE 时生效）。默认 `<repo>/Admin/logs`。
# 生产建议用绝对路径，例如：/var/log/beacon 或 D:\\beacon\\logs
BEACON_LOG_DIR=

# BEACON_LOG_FILE_MAX_MB：单个日志文件最大大小（MB）。默认 50。
BEACON_LOG_FILE_MAX_MB=

# BEACON_LOG_FILE_BACKUP_COUNT：日志轮转保留数量。默认 10。
BEACON_LOG_FILE_BACKUP_COUNT=

# BEACON_LOG_FILE_RETENTION_DAYS：按天保留日志（天数）。
# - 设置为 >0 时：使用“每天 1 份”的轮转策略，并保留最近 N 天（替代 backup_count 按份覆盖方案）。
# - 设置为 0/空 时：保持原有按大小轮转（max_mb + backup_count）。
BEACON_LOG_FILE_RETENTION_DAYS=

# BEACON_DJANGO_DEBUG：Django DEBUG 开关（1=开发模式，0=生产模式）。生产环境必须为 0。
BEACON_DJANGO_DEBUG=1

# BEACON_DJANGO_SECRET_KEY：Django SECRET_KEY（生产必须替换为随机且保密的值）。当 `BEACON_DJANGO_DEBUG=0` 时必须配置且不能以 `django-insecure-` 开头。
BEACON_DJANGO_SECRET_KEY=

# BEACON_DJANGO_ALLOWED_HOSTS：Django ALLOWED_HOSTS（逗号分隔）。当 `BEACON_DJANGO_DEBUG=0` 时必须设置且不能包含 `*`。
BEACON_DJANGO_ALLOWED_HOSTS=*

# BEACON_DJANGO_SESSION_COOKIE_SECURE：是否仅通过 HTTPS 传输 Session Cookie（1=是，0=否）。`BEACON_DJANGO_DEBUG=0` 时默认会开启，除非你显式设为 0（不推荐）。
# BEACON_DJANGO_SESSION_COOKIE_SECURE=1

# BEACON_DJANGO_CSRF_COOKIE_SECURE：是否仅通过 HTTPS 传输 CSRF Cookie（1=是，0=否）。`BEACON_DJANGO_DEBUG=0` 时默认会开启，除非你显式设为 0（不推荐）。
# BEACON_DJANGO_CSRF_COOKIE_SECURE=1

# BEACON_DJANGO_SECURE_SSL_REDIRECT：是否将 HTTP 自动重定向到 HTTPS（1=是，0=否）。如果由反向代理/Nginx 统一处理跳转，这里可保持 0。
# BEACON_DJANGO_SECURE_SSL_REDIRECT=0

# HSTS 仅适用于已经稳定启用 HTTPS 的正式域名；本地 HTTP 开发不要开启。
# BEACON_DJANGO_HSTS_SECONDS=31536000
# BEACON_DJANGO_HSTS_INCLUDE_SUBDOMAINS=0
# BEACON_DJANGO_HSTS_PRELOAD=0

# BEACON_DJANGO_TRUST_X_FORWARDED_PROTO：是否信任反向代理传入的 `X-Forwarded-Proto=https`（1=信任，0=不信任）。反代终止 TLS 时通常需要设为 1。
# BEACON_DJANGO_TRUST_X_FORWARDED_PROTO=1

# BEACON_DJANGO_CSRF_TRUSTED_ORIGINS：Django CSRF 可信来源（逗号分隔，必须带协议，如 `https://beacon.example.com`）。反代/自定义域名部署时需要配置。
# BEACON_DJANGO_CSRF_TRUSTED_ORIGINS=https://beacon.example.com

# ========== SQLite（默认数据库；可选覆盖）==========
# BEACON_SQLITE_DB_PATH：覆盖默认 SQLite 文件路径（默认使用 `Admin/Admin.sqlite3`）。
# 用途：
# - CI / 本机多实例同时跑（避免争用同一个 sqlite 文件）
# - 烟雾测试使用临时 DB（避免污染仓库文件）
BEACON_SQLITE_DB_PATH=

# BEACON_SQLITE_TIMEOUT_SECONDS：SQLite busy timeout（秒，默认 30）。
# SQLite 在多线程/多并发场景下容易出现 "database is locked"，可通过增大该值缓解。
BEACON_SQLITE_TIMEOUT_SECONDS=30

# ========== IFrame 嵌入（集群平台/大屏）==========
# 说明：
# - 默认安全：禁止被任何 iframe 嵌入（防点击劫持）
# - 仅当你明确需要“被第三方平台嵌入”时才开启
#
# BEACON_IFRAME_EMBED_ENABLED：是否允许后台页面被 iframe 嵌入（1=允许）。
# BEACON_IFRAME_EMBED_ENABLED=0
#
# BEACON_IFRAME_EMBED_ALLOWED_ORIGINS：允许嵌入的外部 Origin 白名单（逗号分隔）。
# - 示例：`https://xcnvs.example.com,https://dashboard.example.com`
# - 留空且开启 EMBED 时：仅允许同源嵌入（frame-ancestors 'self'）。
# BEACON_IFRAME_EMBED_ALLOWED_ORIGINS=

# ========== Cloud SaaS v1（云端模式：S3 presign + Edge Token 鉴权）==========
# 以下配置仅在 `BEACON_DEPLOYMENT_MODE=cloud` 时需要。

# BEACON_CLOUD_DB_URL：Cloud 模式数据库连接串（推荐 Postgres；不设置则回退 SQLite）。示例：`postgresql://user:pass@host:5432/dbname`
BEACON_CLOUD_DB_URL=

# BEACON_CLOUD_S3_BUCKET：对象存储 bucket 名称（截图写入位置）。
BEACON_CLOUD_S3_BUCKET=

# BEACON_CLOUD_S3_REGION：S3 region（MinIO 可用 `us-east-1`）。
BEACON_CLOUD_S3_REGION=us-east-1

# BEACON_CLOUD_S3_ENDPOINT_URL：S3 endpoint（MinIO/私有云必填；AWS S3 通常可留空）。
BEACON_CLOUD_S3_ENDPOINT_URL=

# BEACON_CLOUD_S3_ACCESS_KEY_ID：S3 AccessKey（敏感）。
BEACON_CLOUD_S3_ACCESS_KEY_ID=

# BEACON_CLOUD_S3_SECRET_ACCESS_KEY：S3 SecretKey（敏感）。
BEACON_CLOUD_S3_SECRET_ACCESS_KEY=

# BEACON_CLOUD_PRESIGN_PUT_EXPIRES_SECONDS：presigned PUT 有效期（秒，默认 900=15min）。
BEACON_CLOUD_PRESIGN_PUT_EXPIRES_SECONDS=900

# BEACON_CLOUD_PRESIGN_GET_EXPIRES_SECONDS：presigned GET 有效期（秒，默认 60）。
BEACON_CLOUD_PRESIGN_GET_EXPIRES_SECONDS=60

# BEACON_CLOUD_IMAGE_PREVIEW_PROXY：截图预览是否使用 Cloud 代理（1=代理；0=浏览器直连 presigned GET）。Docker/MinIO 场景推荐设为 1。
BEACON_CLOUD_IMAGE_PREVIEW_PROXY=0

# BEACON_CLOUD_EDGE_TOKEN_PEPPER：edge token hash pepper（必须保密；用于 sha256(pepper+token)）。
BEACON_CLOUD_EDGE_TOKEN_PEPPER=

# ========== Cloud SaaS v1（Docker POC / Bootstrap）==========
# 说明：
# - 仅在 docker-compose POC / 自动初始化场景使用
# - 未配置输出文件时不会把 token 打印到日志；请在 Cloud 控制台轮换并复制 token

# BEACON_BOOTSTRAP_ADMIN_USERNAME：自动创建的 Django 超级管理员用户名（默认 admin）。
BEACON_BOOTSTRAP_ADMIN_USERNAME=admin

# BEACON_BOOTSTRAP_ADMIN_PASSWORD：自动创建的 Django 超级管理员密码（生产模式必填）。
BEACON_BOOTSTRAP_ADMIN_PASSWORD=

# BEACON_BOOTSTRAP_EDGE_CLUSTER_NAME：自动创建的边缘集群名称（默认 edge-default）。
BEACON_BOOTSTRAP_EDGE_CLUSTER_NAME=edge-default

# BEACON_BOOTSTRAP_EDGE_TOKEN_FILE：可选的一次性 token 输出路径；文件权限会设为 0600，请作为 Secret 管理。
BEACON_BOOTSTRAP_EDGE_TOKEN_FILE=

# ========== Cloud SaaS v1（边缘模式：上传截图 + 上报告警）==========
# 以下配置仅在 `BEACON_DEPLOYMENT_MODE=edge` 且你希望“告警+截图上云”时需要。

# BEACON_CLOUD_ENABLED：是否启用 cloud sink（1=启用，0=关闭）。
BEACON_CLOUD_ENABLED=0

# BEACON_CLOUD_BASE_URL：Cloud Admin 访问地址（示例：https://cloud.example.com）。
BEACON_CLOUD_BASE_URL=

# BEACON_CLOUD_EDGE_TOKEN：从 Cloud 控制台复制的 edge token（敏感；请用 Secret 注入）。
BEACON_CLOUD_EDGE_TOKEN=

# BEACON_CLOUD_UPLOAD_TIMEOUT_SECONDS：截图 PUT 上传超时（秒，默认 10）。
BEACON_CLOUD_UPLOAD_TIMEOUT_SECONDS=10

# BEACON_CLOUD_INGEST_TIMEOUT_SECONDS：Cloud presign/ingest API 超时（秒，默认 5）。
BEACON_CLOUD_INGEST_TIMEOUT_SECONDS=5

# ========== Alarm Upload（legacy saveAlarmUrl / saveAlarmType=2/3）==========
# 说明：
# - 旧版“上传报警服务器(saveAlarmUrl)”接口依然保留（部分工业客户仍在用）
# - v4.502: 支持仅上传 url（关闭 base64 字段），降低带宽与 CPU 开销
#
# BEACON_ALARM_UPLOAD_INCLUDE_BASE64：是否在 videoArray/imageArray 中包含 base64Str（1=包含；0=仅 url/path）。
BEACON_ALARM_UPLOAD_INCLUDE_BASE64=1

# ========== Alarm Event Bus（报警事件总线：Webhook）==========
# 说明：
# - 这些环境变量用于覆盖 `config.json` 中的报警推送配置（方便生产以 Secret 注入）
# - M1 事件总线采用 DB Outbox（至少一次投递），下游系统需用 `event_id` 幂等去重

# BEACON_ALARM_WEBHOOK_URLS：报警 Webhook 接收地址列表（逗号分隔）。示例：`https://example.com/beacon/webhook,https://backup.example.com/hook`
BEACON_ALARM_WEBHOOK_URLS=

# BEACON_ALARM_WEBHOOK_SECRET：Webhook 签名密钥（可选）。设置后会发送 `X-Beacon-Signature: sha256=<base64>`，用于下游验签。
BEACON_ALARM_WEBHOOK_SECRET=

# BEACON_ALARM_WEBHOOK_TIMEOUT_SECONDS：Webhook 请求超时时间（秒，1~30；默认 5）。
BEACON_ALARM_WEBHOOK_TIMEOUT_SECONDS=5

# ========== License Manager（浮动池授权）==========
# 说明：
# - Admin（Django）负责“验签 + 授权状态 + 租约池（lease pool）”
# - Analyzer（C++）在新增布控 /control/add 时向 Admin 申请租约；运行中周期续租；停止时释放
# - 仅当 Analyzer 配置 `BEACON_LICENSE_TYPE=pool` 或 `manager` 时启用租约门禁；否则保持旧授权逻辑不变

# BEACON_LICENSE_PUBLIC_KEY_B64：License 签名验签公钥（Ed25519，Base64 编码）。用于 Admin 导入/校验 license.json。
BEACON_LICENSE_PUBLIC_KEY_B64=

# BEACON_CLUSTER_ID：集群/项目唯一 ID（建议手工指定；K8s/多机部署请持久化）。用于绑定 license 到“这个集群”，防止拷贝复用。
BEACON_CLUSTER_ID=

# BEACON_LICENSE_TYPE：community（开源默认、无运行授权门禁）或 machine/dongle/pool/manager。
BEACON_LICENSE_TYPE=community

# BEACON_NODE_ID：Analyzer 节点唯一 ID（用于 LM 统计节点数/去重）。不设置时会回退到 `config.json.code` / HOSTNAME / COMPUTERNAME。
BEACON_NODE_ID=

# BEACON_LICENSE_LEASE_TTL_SECONDS：Analyzer 侧租约 TTL（秒，最小 30）。续租间隔一般为 ttl/2，建议 120。
BEACON_LICENSE_LEASE_TTL_SECONDS=120

# BEACON_LICENSE_GRACE_SECONDS：LM 不可用/续租失败时的宽限期（秒）。超过宽限期仍无法续租会自动停止布控（0=无宽限：续租失败立即停止；不推荐）。
BEACON_LICENSE_GRACE_SECONDS=600
