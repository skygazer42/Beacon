# Beacon 环境变量示例（生产/反代/公网）
# ------------------------------------------------------------
# 建议做法：
# 1) 复制为 `.env`
# 2) 把 Token / SecretKey 换成随机长串（不要提交到 Git）
# 3) 明确配置域名、HTTPS、CSRF 可信来源等
#
# 用法（zsh/bash）：
#   set -a
#   source .env
#   set +a

# ========== 部署模式（Edge / Cloud）==========
# BEACON_DEPLOYMENT_MODE：部署模式开关：
# - edge：边缘/本地交付（默认）
# - cloud：云端 SaaS（告警聚合 + 截图上云）
BEACON_DEPLOYMENT_MODE=edge

# BEACON_OPEN_API_TOKEN：开放接口共享 Token（HTTP Header: `X-Beacon-Token`）。生产必须设置为随机长串（>=32），否则 Analyzer -> Admin 的 open API 调用会被拒绝。
BEACON_OPEN_API_TOKEN=

# ZLMediaKit API 密钥。生产必须设置随机长串，并与媒体服务使用同一值。
BEACON_MEDIA_SECRET=

# BEACON_REQUIRE_OPEN_API_TOKEN：生产/反代/公网强制开启（1），避免“反代后 REMOTE_ADDR 变成 127.0.0.1”导致的误放行。
BEACON_REQUIRE_OPEN_API_TOKEN=1

# 本地账号密码最短长度；生产建议至少 12，且仍会执行 Django 的其他密码校验器。
BEACON_PASSWORD_MIN_LENGTH=12

# ========== LDAP/AD 登录（可选）==========
# 说明：
# - /login 在本地认证失败时可回退到 LDAP/AD
# - 认证成功后可自动创建本地用户（便于权限/TOTP 管理）
# - 依赖：需要安装 `ldap3`
BEACON_LDAP_ENABLED=0
BEACON_LDAP_URL=
BEACON_LDAP_USE_SSL=0
BEACON_LDAP_STARTTLS=0
BEACON_LDAP_TLS_VERIFY=1
BEACON_LDAP_CONNECT_TIMEOUT_SECONDS=5
BEACON_LDAP_USER_DN_TEMPLATE=
BEACON_LDAP_BIND_DN=
BEACON_LDAP_BIND_PASSWORD=
BEACON_LDAP_BASE_DN=
BEACON_LDAP_USER_FILTER=
BEACON_LDAP_EMAIL_ATTR=mail

# ========== OAuth2/OIDC SSO 登录（可选）==========
# 说明：
# - 启用后：/login/oidc/start -> OIDC 授权页；/login/oidc/callback -> 交换 code 并登录
# - /logout：若配置 end_session_endpoint，会重定向到 Provider 的 logout
# - 回调地址（Redirect URI）：https://<your-domain>/login/oidc/callback
BEACON_OIDC_ENABLED=0
BEACON_OIDC_CLIENT_ID=
BEACON_OIDC_CLIENT_SECRET=
BEACON_OIDC_AUTHORIZATION_ENDPOINT=
BEACON_OIDC_TOKEN_ENDPOINT=
BEACON_OIDC_USERINFO_ENDPOINT=
BEACON_OIDC_END_SESSION_ENDPOINT=
BEACON_OIDC_SCOPE=openid email profile
# BEACON_OIDC_PROMPT=login
BEACON_OIDC_HTTP_TIMEOUT_SECONDS=8

# 生产推荐开启严格校验（RS256 + JWKS）：
# - 需要在 Provider 侧启用 HTTPS，并配置好 issuer / jwks_uri
BEACON_OIDC_JWKS_URI=
BEACON_OIDC_ISSUER=
BEACON_OIDC_REQUIRE_NONCE=1
BEACON_OIDC_CLOCK_SKEW_SECONDS=60
BEACON_OIDC_JWKS_CACHE_SECONDS=300

# userinfo（可选）
BEACON_OIDC_USERINFO_ENABLED=0
BEACON_OIDC_USERINFO_PREFER=1

# 多 Provider（可选）：使用 JSON 配置多个 Provider，并通过 /login/oidc/start?provider=<id> 选择
BEACON_OIDC_PROVIDER_DEFAULT=
BEACON_OIDC_PROVIDERS_JSON=

# 账号绑定策略（生产推荐）
# - 推荐 create 或 deny，避免 username/email 自动绑定导致账号串号
BEACON_OIDC_ACCOUNT_LINK_MODE=create

# 可选：硬拦截 required groups（企业交付推荐）
# - 配置后：OIDC 回调要求用户至少命中 1 个组，否则直接 403（不会创建/绑定本地账号）
# - 示例：BEACON_OIDC_REQUIRED_GROUPS=beacon_allowed,beacon_admin
BEACON_OIDC_REQUIRED_GROUPS=

# 角色/权限映射（可选）
BEACON_OIDC_STAFF_GROUPS=
BEACON_OIDC_SUPERUSER_GROUPS=
BEACON_OIDC_SYNC_USER_FLAGS=1

# groups -> Admin Web 模块权限 allowlist（可选）
BEACON_OIDC_PERMISSIONS_BY_GROUP_JSON=
BEACON_OIDC_SYNC_USER_PERMISSIONS=0

# ========== TOTP 敏感操作二次确认（可选）==========
# 生产建议：对高风险操作开启（并配置好前缀列表），避免“登录一次后长时间持有敏感权限”
BEACON_TOTP_SENSITIVE_REAUTH_ENABLED=0
BEACON_TOTP_SENSITIVE_REAUTH_WINDOW_SECONDS=300
BEACON_TOTP_SENSITIVE_REAUTH_PREFIXES=

# ========== App-Shell Legacy API 阻断（灰度，可选）==========
# 生产建议：先观察日志，再按环境逐步开启阻断
BEACON_BLOCK_LEGACY_API_FOR_APP_SHELL=0
# 逗号分隔 allowlist，支持 `path/*` 或 `path/` 前缀匹配
BEACON_BLOCK_LEGACY_API_ALLOWLIST=

# ========== 数字人监管运行时（Beacon 本地承接）==========
# 说明：
# - 当前数字人页面与运行时已经直接落在 Beacon，不再需要配置外部数字人后端登录桥接
# - 生产环境至少应明确配置 machineCode 相关密钥、共享防重放 Redis 和截图对象存储

# 与采集端 machineCode 生成逻辑保持一致；未配置时相关接口返回 503
BEACON_DIGITAL_HUMAN_AUTHORIZATION_SECRET=

# 与采集端 report Authorization 加密逻辑保持一致；未配置时相关接口返回 503
BEACON_DIGITAL_HUMAN_UPLOAD_AUTH_SM4_SECRET_KEY=

# 设备默认上报间隔（秒）
BEACON_DIGITAL_HUMAN_REPORT_DEFAULT_INTERVAL_SEC=30

# 设备截图大小上限（字节）
BEACON_DIGITAL_HUMAN_REPORT_IMAGE_MAX_BYTES=524288

# 多实例共享防重放 Redis（强烈建议生产配置）
BEACON_DIGITAL_HUMAN_REPLAY_REDIS_URL=

# 兼容别名；若未设置专用地址可复用
BEACON_DIGITAL_HUMAN_REDIS_URL=

# 防重放 key 前缀
BEACON_DIGITAL_HUMAN_REPLAY_CACHE_PREFIX=beacon:digital-human:replay

# 数字人截图对象存储 bucket；不设置则回退到 BEACON_CLOUD_S3_BUCKET 或本地 uploadDir
BEACON_DIGITAL_HUMAN_S3_BUCKET=

# ========== 报警落库前“大模型预检”（可选）==========
# 说明：
# - 在报警写入数据库/写盘前，先调用外部预检服务进行二次过滤（例如：大模型预检、黑白名单、业务规则等）
# - 工业默认建议 fail-open（预检服务抖动时不丢报警）；如你明确要“宁可误丢也不误报”，可改 fail-open=0
BEACON_ALARM_PRECHECK_ENABLED=0
BEACON_ALARM_PRECHECK_URL=
BEACON_ALARM_PRECHECK_TIMEOUT_SECONDS=5
BEACON_ALARM_PRECHECK_FAIL_OPEN=1

# ========== OpenAPI 文件服务（可选，只读下载）==========
# 安全建议：仅在内网/可信反代环境启用
BEACON_FILE_SERVICE_ENABLED=0
BEACON_FILE_SERVICE_ROOT_DIR=

# ========== USB 摄像头桥接（可选，本机采集 -> RTMP 推流） ==========
# 说明：
# - Beacon 继续消费标准网络流；USB 摄像头通过本机 ffmpeg bridge 推到 MediaServer
# - Linux 常用默认值：v4l2 + /dev/video0
# - 设备未插入时 bridge 会启动失败，但主服务仍可启动；插入设备后重启软件或等待守护重试
BEACON_USB_CAMERA_ENABLED=0
BEACON_USB_CAMERA_FFMPEG_BIN=ffmpeg
BEACON_USB_CAMERA_INPUT_DRIVER=v4l2
BEACON_USB_CAMERA_INPUT_FORMAT=mjpeg
BEACON_USB_CAMERA_VIDEO_SIZE=1280x720
BEACON_USB_CAMERA_FRAMERATE=25
BEACON_USB_CAMERA_DEVICE=/dev/video0
BEACON_USB_CAMERA_APP=live
BEACON_USB_CAMERA_STREAM_NAME=usbcam
BEACON_USB_CAMERA_PUBLISH_URL=

# BEACON_UPLOAD_DIR：覆盖 `config.json.uploadDir`（报警视频/截图/录制等落盘目录）。生产建议用绝对路径（如 /data/beacon/upload），并确保磁盘有足够空间与留存策略。
BEACON_UPLOAD_DIR=

# BEACON_MODEL_DIR：覆盖 `config.json.modelDir`（模型文件目录）。生产建议用绝对路径（如 /data/beacon/models），并通过挂载/镜像分层交付模型。
BEACON_MODEL_DIR=

# ========== API 推理（外部服务）稳定性保护 ==========
# 说明：
# - 仅影响 `basic_source=api` 类型的基础算法（调用外部 HTTP 推理服务）
# - 推荐在生产通过环境变量配置（便于按环境调整、避免改动 config.json）
# - 目标：外部推理服务异常时，快速失败/熔断/限流，避免队列堆积导致 Analyzer 崩溃

# BEACON_API_INFER_CONNECT_TIMEOUT_SECONDS：API 推理服务连接超时（秒，默认 2；范围 1~60）。
BEACON_API_INFER_CONNECT_TIMEOUT_SECONDS=

# BEACON_API_INFER_TIMEOUT_SECONDS：API 推理服务请求总超时（秒，默认 5；范围 1~300）。外部服务较慢可适当增大。
BEACON_API_INFER_TIMEOUT_SECONDS=

# BEACON_API_INFER_RETRY_MAX：API 推理失败重试次数（默认 0；范围 0~10）。生产建议 0 或 1，避免重试风暴。
BEACON_API_INFER_RETRY_MAX=

# BEACON_API_INFER_CIRCUIT_BREAKER_FAILS：熔断阈值（连续失败次数，默认 5；范围 0~100；0=禁用熔断）。
BEACON_API_INFER_CIRCUIT_BREAKER_FAILS=

# BEACON_API_INFER_CIRCUIT_BREAKER_OPEN_SECONDS：熔断打开时长（秒，默认 10；范围 0~3600）。打开期间会跳过 API 推理以保护系统稳定。
BEACON_API_INFER_CIRCUIT_BREAKER_OPEN_SECONDS=

# BEACON_API_INFER_MIN_INTERVAL_MS：API 推理最小调用间隔（毫秒，默认 0；0=禁用）。用于限流，适合弱机/高路数场景。
BEACON_API_INFER_MIN_INTERVAL_MS=

# ========== GB28181 外部平台适配（WVP / 自研平台） ==========
# 说明：
# - Admin 通过 provider API 获取“可播放 play_url”（RTSP/HTTP-FLV/HLS 等），再用本机 ZLM `addStreamProxy` 拉回
# - Analyzer 始终从本机 ZLM 拉流，避免对 Analyzer 引入 SIP/GB 信令依赖
# - 模板支持占位符：{deviceId} {channelId}

# BEACON_GB28181_PROVIDER：GB28181 外部平台类型（wvp/custom）。默认 wvp。
BEACON_GB28181_PROVIDER=wvp

# BEACON_GB28181_WVP_BASE_URL：WVP 平台 API Base URL（示例：http://wvp:18080）。
BEACON_GB28181_WVP_BASE_URL=

# BEACON_GB28181_WVP_START_PLAY_URL_TEMPLATE：WVP 启动点播模板（示例：/api/gb/start?deviceId={deviceId}&channelId={channelId}）。
BEACON_GB28181_WVP_START_PLAY_URL_TEMPLATE=

# BEACON_GB28181_WVP_STOP_PLAY_URL_TEMPLATE：WVP 停止点播模板（示例：/api/gb/stop?deviceId={deviceId}&channelId={channelId}）。
BEACON_GB28181_WVP_STOP_PLAY_URL_TEMPLATE=

# BEACON_GB28181_CUSTOM_BASE_URL：自研平台 API Base URL（示例：http://custom-gb:28080）。
BEACON_GB28181_CUSTOM_BASE_URL=

# BEACON_GB28181_CUSTOM_START_PLAY_URL_TEMPLATE：自研平台启动点播模板（支持 {deviceId} {channelId}）。
BEACON_GB28181_CUSTOM_START_PLAY_URL_TEMPLATE=

# BEACON_GB28181_CUSTOM_STOP_PLAY_URL_TEMPLATE：自研平台停止点播模板（支持 {deviceId} {channelId}）。
BEACON_GB28181_CUSTOM_STOP_PLAY_URL_TEMPLATE=

# BEACON_GB28181_HTTP_TIMEOUT_SECONDS：provider HTTP 超时（秒，默认 8；范围 1~60）。
BEACON_GB28181_HTTP_TIMEOUT_SECONDS=

# BEACON_FRAMEPOOL_MAX_FRAMES：Analyzer 内部 FramePool 最大帧数（总量上限）。
# 说明：
# - 用于防止弱机或多路布控下“生产 > 消费”导致内存暴涨/崩溃
# - 设置为正整数（例如 60/80/120）
# - 留空或 0 表示自动：按 `BEACON_FRAMEPOOL_BUDGET_MB` 预算 + 分辨率估算（默认 128MB）
# - 1080p BGR 单帧约 6MB：20 帧≈120MB；80 帧≈480MB（仅 FramePool 上限，不含其他内存）
BEACON_FRAMEPOOL_MAX_FRAMES=

# BEACON_FRAMEPOOL_BUDGET_MB：当未设置 `BEACON_FRAMEPOOL_MAX_FRAMES` 时，FramePool 自动上限预算（单位 MB，默认 128）。
# 建议：
# - 弱机（内存较小/多路布控）：64 或 32
# - 高配/少路数：可适当调高
BEACON_FRAMEPOOL_BUDGET_MB=

# BEACON_DISABLE_BACKGROUND：生产通常保持启用（0）。如需临时关闭某些后台任务可改为 1。
BEACON_DISABLE_BACKGROUND=0

# DJANGO_DEBUG_STARTUP_LOGS：生产建议关闭（0）。
DJANGO_DEBUG_STARTUP_LOGS=0

# ========== OpenTelemetry Tracing（可选；Admin/Analyzer/MediaServer）==========
# 说明：
# - 默认关闭；仅在需要链路追踪排障时启用
# - Trace context：W3C traceparent（Admin requests 出站会自动传播）
# - Admin（Django）：OTLP/HTTP exporter（常见 collector 端口 4318，路径通常为 /v1/traces）
# - Analyzer（C++）：
#   - 若以 `-DBEACON_ENABLE_OTEL=ON` 构建并链接 opentelemetry-cpp：使用 OTLP/HTTP exporter
#   - 否则（默认/轻量构建）：best-effort 使用 Zipkin v2 JSON exporter（通过 collector 的 Zipkin receiver 接入）
# - MediaServer（ZLMediaKit）：best-effort 使用 Zipkin v2 JSON exporter（通过 collector 的 Zipkin receiver 接入）
# - 工业推荐：统一接入 OpenTelemetry Collector（可同时接收 OTLP 4317/4318 + Zipkin 9411，再转发到 Jaeger/Tempo 等后端）
#
# BEACON_OTEL_ENABLED：是否启用 OpenTelemetry tracing（1=启用，0=禁用）。
BEACON_OTEL_ENABLED=0
#
# BEACON_OTEL_OTLP_ENDPOINT：OTLP HTTP endpoint（可填 base 或完整 /v1/traces）。
# 示例（base）：http://otel-collector:4318
# 示例（full）：http://otel-collector:4318/v1/traces
BEACON_OTEL_OTLP_ENDPOINT=
#
# 可选：Zipkin endpoint（用于 MediaServer 与 Analyzer 轻量 exporter；不设则会尝试从 OTLP endpoint 推导到 :9411/api/v2/spans）。
# 示例（base）：http://otel-collector:9411
# 示例（full）：http://otel-collector:9411/api/v2/spans
BEACON_OTEL_ZIPKIN_ENDPOINT=
#
# BEACON_OTEL_SAMPLE_RATIO：采样率（0..1）。生产建议从 0.1 开始按需调整。
BEACON_OTEL_SAMPLE_RATIO=0.1
#
# 可选：服务名（不设时默认 beacon-admin；也可使用标准 OTEL_SERVICE_NAME）。
# BEACON_OTEL_SERVICE_NAME=beacon-admin
#
# 标准 OTEL_* 兼容（可选）：
# OTEL_SERVICE_NAME=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_ZIPKIN_ENDPOINT=

# BEACON_LOG_LEVEL：日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）。生产建议 INFO 或 WARNING。
BEACON_LOG_LEVEL=INFO

# BEACON_LOG_FORMAT：日志格式（text/json）。生产建议 json（便于集中采集与检索）。
BEACON_LOG_FORMAT=json

# BEACON_LOG_TO_FILE：生产建议开启（1），同时写入本地轮转文件，便于离线排障。
BEACON_LOG_TO_FILE=1

# BEACON_LOG_DIR：日志目录（建议绝对路径）。
BEACON_LOG_DIR=./logs

# BEACON_LOG_FILE_MAX_MB：单个日志文件最大大小（MB）。默认 50。
BEACON_LOG_FILE_MAX_MB=50

# BEACON_LOG_FILE_BACKUP_COUNT：日志轮转保留数量。默认 10。
BEACON_LOG_FILE_BACKUP_COUNT=10

# BEACON_LOG_FILE_RETENTION_DAYS：按天保留日志（天数）。
# - 设置为 >0 时：使用“每天 1 份”的轮转策略，并保留最近 N 天（替代 backup_count 按份覆盖方案）。
# - 设置为 0 时：保持原有按大小轮转（max_mb + backup_count）。
BEACON_LOG_FILE_RETENTION_DAYS=30

# BEACON_DJANGO_DEBUG：生产必须为 0（关闭 DEBUG）。开启后会放宽 ALLOWED_HOSTS，并且泄露更多调试信息。
BEACON_DJANGO_DEBUG=0

# BEACON_DJANGO_SECRET_KEY：生产必须设置为随机且保密的值（可用 Django/openssl 生成）。占位值以 `django-insecure-` 开头会触发启动时报错，强制你替换。
BEACON_DJANGO_SECRET_KEY=django-insecure-please-change-me

# BEACON_DJANGO_ALLOWED_HOSTS：生产必须明确设置域名/IP（逗号分隔），且不能包含 `*`。示例：`beacon.example.com,beacon.internal`
BEACON_DJANGO_ALLOWED_HOSTS=beacon.example.com

# BEACON_DJANGO_SESSION_COOKIE_SECURE：生产建议开启（1），让浏览器只在 HTTPS 下发送 Session Cookie。
BEACON_DJANGO_SESSION_COOKIE_SECURE=1

# BEACON_DJANGO_CSRF_COOKIE_SECURE：生产建议开启（1），让浏览器只在 HTTPS 下发送 CSRF Cookie。
BEACON_DJANGO_CSRF_COOKIE_SECURE=1

# BEACON_DJANGO_TRUST_X_FORWARDED_PROTO：反代终止 TLS 时建议开启（1），让 Django 正确识别“外部是 https”。
BEACON_DJANGO_TRUST_X_FORWARDED_PROTO=1

# BEACON_DJANGO_SECURE_SSL_REDIRECT：是否强制将 HTTP 跳转到 HTTPS（1=开启）。如果你的反代已做 80->443 跳转，可保持 0。
BEACON_DJANGO_SECURE_SSL_REDIRECT=0

# HSTS 只能在域名已稳定启用 HTTPS 后开启；误开会让浏览器长期拒绝 HTTP。
BEACON_DJANGO_HSTS_SECONDS=31536000
BEACON_DJANGO_HSTS_INCLUDE_SUBDOMAINS=0
BEACON_DJANGO_HSTS_PRELOAD=0

# BEACON_DJANGO_CSRF_TRUSTED_ORIGINS：生产必须设置为外部访问的 Origin（逗号分隔，必须带协议）。示例：`https://beacon.example.com`
BEACON_DJANGO_CSRF_TRUSTED_ORIGINS=https://beacon.example.com

# ========== SQLite（默认数据库；可选覆盖）==========
# BEACON_SQLITE_DB_PATH：覆盖默认 SQLite 文件路径（默认使用 `Admin/Admin.sqlite3`）。
# 用途：
# - 多实例同机部署（避免争用同一个 sqlite 文件）
# - 运维/排障时切换到单独的 DB 文件
BEACON_SQLITE_DB_PATH=

# BEACON_SQLITE_TIMEOUT_SECONDS：SQLite busy timeout（秒，默认 30）。
BEACON_SQLITE_TIMEOUT_SECONDS=30

# ========== IFrame 嵌入（集群平台/大屏）==========
# 生产默认建议保持关闭，避免点击劫持风险。只有当你确实需要被 iframe 嵌入时才开启。
BEACON_IFRAME_EMBED_ENABLED=0

# 若需外部站点嵌入，请配置 allowlist（逗号分隔）；留空时仅允许同源。示例：`https://xcnvs.example.com`
BEACON_IFRAME_EMBED_ALLOWED_ORIGINS=

# ========== Cloud SaaS v1（云端模式：S3 presign + Edge Token 鉴权）==========
# 以下配置仅在 `BEACON_DEPLOYMENT_MODE=cloud` 时需要。

# BEACON_CLOUD_DB_URL：Cloud 模式数据库连接串（推荐 Postgres；不设置则回退 SQLite）。示例：`postgresql://user:pass@host:5432/dbname`
BEACON_CLOUD_DB_URL=

# BEACON_CLOUD_S3_BUCKET：对象存储 bucket 名称（截图写入位置）。
BEACON_CLOUD_S3_BUCKET=

# BEACON_CLOUD_S3_REGION：S3 region（MinIO 可用 `us-east-1`）。
BEACON_CLOUD_S3_REGION=us-east-1

# BEACON_CLOUD_S3_ENDPOINT_URL：S3 endpoint（MinIO/私有云必填；AWS S3 通常可留空）。
BEACON_CLOUD_S3_ENDPOINT_URL=

# BEACON_CLOUD_S3_ACCESS_KEY_ID：S3 AccessKey（敏感）。
BEACON_CLOUD_S3_ACCESS_KEY_ID=

# BEACON_CLOUD_S3_SECRET_ACCESS_KEY：S3 SecretKey（敏感）。
BEACON_CLOUD_S3_SECRET_ACCESS_KEY=

# BEACON_CLOUD_PRESIGN_PUT_EXPIRES_SECONDS：presigned PUT 有效期（秒，默认 900=15min）。
BEACON_CLOUD_PRESIGN_PUT_EXPIRES_SECONDS=900

# BEACON_CLOUD_PRESIGN_GET_EXPIRES_SECONDS：presigned GET 有效期（秒，默认 60）。
BEACON_CLOUD_PRESIGN_GET_EXPIRES_SECONDS=60

# BEACON_CLOUD_IMAGE_PREVIEW_PROXY：截图预览是否使用 Cloud 代理（1=代理；0=浏览器直连 presigned GET）。
# 说明：
# - Docker/MinIO 场景推荐 1（避免 presigned GET 指向 docker 内部域名导致浏览器不可达）
# - 生产建议 0（浏览器直连对象存储，节省 Cloud 带宽），前提是对象存储对浏览器可达
BEACON_CLOUD_IMAGE_PREVIEW_PROXY=0

# BEACON_CLOUD_EDGE_TOKEN_PEPPER：edge token hash pepper（必须保密；用于 sha256(pepper+token)）。
BEACON_CLOUD_EDGE_TOKEN_PEPPER=

# ========== Cloud SaaS v1（Docker POC / Bootstrap）==========
# 说明：
# - 仅用于 docker-compose POC / 自动初始化
# - 未配置输出文件时不会把 token 打印到日志；请在 Cloud 控制台轮换并复制 token

# BEACON_BOOTSTRAP_ADMIN_USERNAME：自动创建的 Django 超级管理员用户名（默认 admin）。
BEACON_BOOTSTRAP_ADMIN_USERNAME=admin

# BEACON_BOOTSTRAP_ADMIN_PASSWORD：自动创建的 Django 超级管理员密码（生产必填）。
BEACON_BOOTSTRAP_ADMIN_PASSWORD=

# BEACON_BOOTSTRAP_EDGE_CLUSTER_NAME：自动创建的边缘集群名称（默认 edge-default）。
BEACON_BOOTSTRAP_EDGE_CLUSTER_NAME=edge-default

# BEACON_BOOTSTRAP_EDGE_TOKEN_FILE：可选的一次性 token 输出路径；文件权限会设为 0600，请作为 Secret 管理。
BEACON_BOOTSTRAP_EDGE_TOKEN_FILE=

# ========== Cloud SaaS v1（边缘模式：上传截图 + 上报告警）==========
# 以下配置仅在 `BEACON_DEPLOYMENT_MODE=edge` 且你希望“告警+截图上云”时需要。

# BEACON_CLOUD_ENABLED：是否启用 cloud sink（1=启用，0=关闭）。
BEACON_CLOUD_ENABLED=0

# BEACON_CLOUD_BASE_URL：Cloud Admin 访问地址（示例：https://cloud.example.com）。
BEACON_CLOUD_BASE_URL=

# BEACON_CLOUD_EDGE_TOKEN：从 Cloud 控制台复制的 edge token（敏感；请用 Secret 注入）。
BEACON_CLOUD_EDGE_TOKEN=

# BEACON_CLOUD_UPLOAD_TIMEOUT_SECONDS：截图 PUT 上传超时（秒，默认 10）。
BEACON_CLOUD_UPLOAD_TIMEOUT_SECONDS=10

# BEACON_CLOUD_INGEST_TIMEOUT_SECONDS：Cloud presign/ingest API 超时（秒，默认 5）。
BEACON_CLOUD_INGEST_TIMEOUT_SECONDS=5

# ========== Alarm Upload（legacy saveAlarmUrl / saveAlarmType=2/3）==========
# 说明：
# - 旧版“上传报警服务器(saveAlarmUrl)”接口仍可用（部分客户旧系统仍依赖）
# - v4.502: 支持关闭 base64 字段，仅上传 url/path，降低带宽与 CPU
#
# BEACON_ALARM_UPLOAD_INCLUDE_BASE64：是否在 videoArray/imageArray 中包含 base64Str（1=包含；0=仅 url/path）。
BEACON_ALARM_UPLOAD_INCLUDE_BASE64=1

# ========== Alarm Event Bus（报警事件总线：Webhook）==========
# 说明：
# - 建议通过环境变量注入 Webhook 的敏感配置（地址/密钥），避免写入 config.json
# - M1 事件总线采用 DB Outbox（至少一次投递），下游系统必须用 `event_id` 幂等去重（允许重复投递）

# BEACON_ALARM_WEBHOOK_URLS：报警 Webhook 接收地址列表（逗号分隔）。生产建议必须设置为 HTTPS，并在接收端做鉴权/签名校验。
BEACON_ALARM_WEBHOOK_URLS=

# BEACON_ALARM_WEBHOOK_SECRET：Webhook 签名密钥（可选但强烈建议设置）。设置后会发送 `X-Beacon-Signature: sha256=<base64>`。
BEACON_ALARM_WEBHOOK_SECRET=

# BEACON_ALARM_WEBHOOK_TIMEOUT_SECONDS：Webhook 超时时间（秒，1~30；默认 5）。
BEACON_ALARM_WEBHOOK_TIMEOUT_SECONDS=5

# ========== License Manager（浮动池授权）==========
# 说明：
# - Admin（Django）是 License Manager：负责“验签 + 授权状态 + 租约池（lease pool）”
# - Analyzer（C++）在新增布控前必须成功申请租约；运行中周期续租；停止时释放
# - 仅当 Analyzer 配置 `BEACON_LICENSE_TYPE=pool` 或 `manager` 时启用租约门禁；否则保持旧授权逻辑不变

# BEACON_LICENSE_PUBLIC_KEY_B64：License 签名验签公钥（Ed25519，Base64 编码）。生产建议必须配置，避免误导入/无法诊断。
BEACON_LICENSE_PUBLIC_KEY_B64=

# BEACON_CLUSTER_ID：集群/项目唯一 ID（生产强烈建议显式指定并持久化；K8s 推荐用 Secret/PVC/ConfigMap 注入）。用于绑定 license 到集群。
BEACON_CLUSTER_ID=

# BEACON_LICENSE_TYPE：community/machine/dongle/pool/manager。生产示例使用 pool；只有 pool/manager 才启用“租约门禁 + 浮动池计费”。
BEACON_LICENSE_TYPE=pool
BEACON_LICENSE_KEY=

# BEACON_NODE_ID：Analyzer 节点唯一 ID（生产必须保证每个节点不同）。K8s 可用 StatefulSet Pod 名/节点序号；多机可用资产编号/主机名。
BEACON_NODE_ID=

# BEACON_LICENSE_LEASE_TTL_SECONDS：Analyzer 侧租约 TTL（秒，最小 30）。建议 120；过小会增加续租压力，过大回收慢。
BEACON_LICENSE_LEASE_TTL_SECONDS=120

# BEACON_LICENSE_GRACE_SECONDS：LM 不可用/续租失败时的宽限期（秒）。建议 600；到期仍失败会自动停止布控以保证计费/合规（0=无宽限：续租失败立即停止；不推荐）。
BEACON_LICENSE_GRACE_SECONDS=600
