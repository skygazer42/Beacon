# Copy this file to `.env`, replace every CHANGE_ME value, then run Docker Compose.
# Keep `.env` private; it is ignored by Git.

BEACON_CLOUD_DB_NAME=beacon
BEACON_CLOUD_DB_USER=beacon
BEACON_CLOUD_DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
# URL-encode reserved characters in the username/password portion of this URL.
BEACON_CLOUD_DB_URL=postgresql://beacon:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/beacon

MINIO_ROOT_USER=beacon-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

BEACON_OPEN_API_TOKEN=CHANGE_ME_RANDOM_TOKEN_AT_LEAST_32_CHARS
BEACON_DJANGO_SECRET_KEY=CHANGE_ME_RANDOM_DJANGO_KEY_AT_LEAST_32_CHARS
BEACON_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,beacon-cloud
BEACON_CLOUD_EDGE_TOKEN_PEPPER=CHANGE_ME_RANDOM_PEPPER_AT_LEAST_32_CHARS
BEACON_BOOTSTRAP_ADMIN_USERNAME=admin
BEACON_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
BEACON_BOOTSTRAP_EDGE_TOKEN_FILE=/demo/edge_token.txt

# Required only when compose.monitoring.yml is enabled.
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# For HTTPS behind a reverse proxy, enable all three and set the public origin.
BEACON_DJANGO_SESSION_COOKIE_SECURE=0
BEACON_DJANGO_CSRF_COOKIE_SECURE=0
BEACON_DJANGO_TRUST_X_FORWARDED_PROTO=0
BEACON_DJANGO_CSRF_TRUSTED_ORIGINS=
